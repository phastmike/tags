<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkPopover" id="popover_file_info">
    <child>
      <object class="GtkBox">
        <child>
          <object class="GtkListBox">
            <style>
              <class name="rich-list"/>
              <class name="boxed-list"/>
            </style>
            <child>
              <object class="GtkListBoxRow">
                <property name="activatable">false</property>
                <property name="selectable">false</property>
                <child>
                  <object class="GtkBox">
                    <child>
                      <object class="GtkLabel">
                        <property name="label">Filename</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
    <!--
    <child>
      <object class="GtkLabel">
        <property name="margin-start">8</property>
        <property name="margin-end">8</property>
        <property name="margin-top">8</property>
        <property name="margin-bottom">8</property>
        <property name="wrap">true</property>
        <property name="max-width-chars">36</property>
        <property name="label" translatable="yes">Automatically loads the tags file, if there is a file with the same name as the file you are about to open and the extension .tags on the same path</property>
      </object>
    </child>
    -->
  </object>
  <template class="TaggerWindow" parent="GtkApplicationWindow">
    <property name="title" translatable="yes">Tagger</property>
    <property name="default-width">1024</property>
    <property name="default-height">768</property>
    <style>
       <class name="flat"/>
       <!--
       <class name="devel"/>
       -->
    </style>
    <child type="titlebar">
      <object class="GtkHeaderBar" id="header_bar">
        <!--
        <property name="title-widget">
          <object class="GtkLabel">
            <property name="label" translatable="yes">Tagger</property>
            <property name="single-line-mode">True</property>
            <property name="ellipsize">end</property>
            <property name="width-chars">5</property>
            <style>
              <class name="title"/>
            </style>
          </object>
        </property>
        -->

        <property name="title-widget">
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="homogeneous">true</property>
            <child>
              <object class="GtkLabel">
                <property name="label" translatable="yes">Tagger</property>
                <property name="single-line-mode">True</property>
                <property name="ellipsize">none</property>
                <property name="width-chars">5</property>
                <style>
                  <class name="title"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="subtitle">
                <property name="label" translatable="yes">Open a file to get started ...</property>
                <property name="has-tooltip">true</property>
                <property name="single-line-mode">True</property>
                <property name="ellipsize">end</property>
                <property name="width-chars">5</property>
                <style>
                  <class name="subtitle"/>
                </style>
              </object>
            </child>
          </object>
        </property>
        <child type="end">
          <object class="GtkMenuButton">
            <property name="primary">true</property>
            <property name="icon-name">open-menu-symbolic</property>
            <property name="menu-model">primary_menu</property>
          </object>
      </child>
      <child type="start">
        <object class="GtkButton" id="button_open_file">
         <property name="visible">true</property>
         <property name="icon_name">document-open-symbolic</property>
         <property name="tooltip_text" translatable="yes">Open File</property>
       </object>
      </child>
      <child type="start">
        <object class="GtkMenuButton">
          <property name="visible">false</property>
          <property name="icon_name">document-properties-symbolic</property>
          <property name="tooltip_text" translatable="yes">File properties</property>
          <property name="popover">popover_file_info</property>
          <style>
            <class name="toggle"/>
          </style>
        </object>
      </child>
      <child type="end">
        <object class="GtkBox">
          <style>
            <class name="linked"/>
          </style>
          <property name="orientation">horizontal</property>
          <child>
            <object class="GtkButton" id="button_tags">
              <property name="visible">true</property>
              <property name="label">Tags</property>
              <property name="tooltip_text" translatable="yes">Add Tag</property>
              <property name="icon_name">bookmark-new-symbolic</property>
            </object>
          </child>
          <!--
          <child>
            <object class="GtkToggleButton" id="button_toggle_taglist_visibility">
              <property name="visible">true</property>
              <property name="label">TagList</property>
              <property name="tooltip_text" translatable="yes">Toogle Taglist visibility</property>
              <property name="icon_name">media-view-subtitles-symbolic</property>
            </object>
          </child>
          <child>
            <object class="GtkToggleButton" id="button_toggle_untagged_visibility">
              <property name="visible">true</property>
              <property name="label">Untagged visibility</property>
              <property name="tooltip_text" translatable="yes">Toogle untagged visibility</property>
              <property name="icon_name">view-continuous-symbolic</property>
            </object>
         </child>
          -->
          <child>
            <object class="GtkMenuButton">
              <property name="visible">true</property>
              <property name="valign">center</property>
              <property name="popover">file_popover</property>
              <property name="tooltip_text" translatable="yes">Tags menu</property>
            </object>
          </child>
        </object>
      </child>
      <!--
      <child type="end">
        <object class="GtkMenuButton">
          <property name="visible">true</property>
          <property name="valign">center</property>
          <property name="popover">file_popover</property>
        </object>
      </child>
      <child type="end">
        <object class="GtkButton" id="xbutton_tags">
          <property name="visible">true</property>
          <property name="label">Tags</property>
          <property name="icon_name">bookmark-new-symbolic</property>
        </object>
      </child>
      -->
      </object>
    </child>
  </template>

  <object class="GtkPopover" id="fpop">
    <child>
      <object class="GtkBox" id="open_button_box">
        <property name="visible">true</property>
        <child>
          <object class="GtkLabel" id="open_button_name">
            <property name="label" translatable="yes">_Open</property>
            <property name="use-underline">true</property>
            <property name="visible">true</property>
            <property name="valign">baseline</property>
          </object>
        </child>
        <child>
          <object class="GtkImage" id="open_button_arrow">
            <property name="visible">true</property>
            <property name="valign">baseline</property>
            <property name="icon_name">pan-down-symbolic</property>
          </object>
        </child>
      </object>
    </child>
  </object>

  <object class="GtkPopoverMenu" id="file_popover">
   <property name="menu-model">file_menu</property>
  </object>

  <menu id="file_menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">New Tag</attribute>
        <attribute name="action">win.add_tag</attribute>
      </item>
    </section>  
    <section>
      <item>
        <attribute name="label" translatable="yes">Save Tagged</attribute>
        <attribute name="action">win.save_tagged</attribute>
        <attribute name="hidden-when">action-disabled</attribute>
      </item>
    </section> 
    <section>
      <item>
        <attribute name="label" translatable="yes">Load Tags</attribute>
        <attribute name="action">win.load_tags</attribute>
        <!-- <attribute name="icon">document-open-symbolic.symbolic</attribute> -->
      </item>
      <item>
        <attribute name="label" translatable="yes">Save Tags</attribute>
        <attribute name="action">win.save_tags</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Remove Tags</attribute>
        <attribute name="action">win.remove_all_tags</attribute>
      </item>
    </section>
    <section>
      <!-- <attribute name="label" translatable="yes" context="menu item" comments="Translators: ...">UI</attribute> -->
      <item>
        <attribute name="label" translatable="yes">Hide Tag list</attribute>
        <attribute name="action">win.toggle_tags_view</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Hide Untagged</attribute>
        <attribute name="action">win.hide_untagged_lines</attribute>
      </item>
    </section>
  </menu>

  <menu id="primary_menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">New Window</attribute>
        <attribute name="action">app.new_window</attribute>
      </item>
    </section>  
    <section>
      <item>
        <attribute name="label" translatable="yes">Preferences</attribute>
        <attribute name="action">app.preferences</attribute>
      </item>
    </section>  
    <section>  
      <item>
        <attribute name="label" translatable="yes">Keyboard Shortcuts</attribute>
        <attribute name="action">win.show-help-overlay</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">About Tagger</attribute>
        <attribute name="action">app.about</attribute>
      </item>
    </section>
  </menu>
</interface>
